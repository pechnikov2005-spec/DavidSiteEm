@page
@model DavidSiteEm.Pages.Applications.NewApplicationModel
@{
    ViewData["Title"] = "Новая заявка";
}

<div class="card">
    <h1>Подать заявку на обучение</h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label>Наименование курса</label>
            <input name="CourseName" value="@Model.CourseName" placeholder="Например: Управление проектами" required/>
        </div>
        <div class="form-group">
            <label>Желаемая дата начала обучения</label>
            <input type="date" name="StartDate" value="@Model.StartDate" required/>
        </div>
        <div class="form-group">
            <label>Способ оплаты</label>
            <select name="PaymentMethod">
                <option value="cash">Наличными</option>
                <option value="transfer">Перевод по номеру телефона</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Отправить</button>
        <a asp-page="/Applications/Index" class="btn btn-secondary" style="margin-left:0.5rem;">Отмена</a>
    </form>
</div>
